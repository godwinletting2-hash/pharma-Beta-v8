# ── Required ──────────────────────────────────────────────────────────────────
# Get your free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── Optional: override the default SQLite path ────────────────────────────────
# SQLite is the default (zero-config, great for development and small deploys).
# ⚠️  RAILWAY WARNING: the filesystem is EPHEMERAL — the database and all
# uploaded files are wiped on every redeploy / container restart.
#
# For persistent storage on Railway:
#   1. Add a PostgreSQL plugin in your Railway project.
#   2. Set PHARMASCAN_DATABASE_URL to the Postgres URL Railway provides.
#   3. For uploaded files, mount a Railway Volume at ./uploaded_notes or use an
#      external object store (e.g. Cloudflare R2, AWS S3).
#
# PHARMASCAN_DATABASE_URL=sqlite+aiosqlite:///./pharmascan.db
# PHARMASCAN_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/pharmascanke

# ── Optional: community channel links ─────────────────────────────────────────
# When set, a join-us footer is appended to every AI analysis response.
# WHATSAPP_CHANNEL_URL=https://chat.whatsapp.com/your_invite_link
# TELEGRAM_CHANNEL_URL=https://t.me/your_channel

# ── Optional: override defaults ───────────────────────────────────────────────
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_TOKENS=8192
# GROQ_TEMPERATURE=0.3
# MAX_UPLOAD_SIZE_MB=50
# DEBUG=false
